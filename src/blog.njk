<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Auctologue Blog</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Pinyon+Script&display=swap" rel="stylesheet" />
  <style>
    /* Base styles matching index.html */
    :root {
      --primary-blue: #3b82f6;
      --dark-blue: #2563eb;
      --accent-blue: #60a5fa;
      --brand-blue: #93c5fd;
      --text-primary: #e5e7eb;
      --text-secondary: #cbd5e1;
      --text-muted: #94a3b8;
      --bg: #0b1220;
      --border: #1f2937;
      --panel: #111827;
      --radius: 18px;
      --max: 1120px;
      --link-color: #93c5fd;
      --page-bg: radial-gradient(circle at 8% 0%, rgba(59, 130, 246, 0.22), transparent 42%), radial-gradient(circle at 92% 12%, rgba(59, 130, 246, 0.15), transparent 38%), linear-gradient(180deg, #162744 0%, #111f35 26%, #0f1a2d 55%, var(--bg) 100%);
      --nav-bg: #1b3760;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: "Inter", system-ui, -apple-system, "Segoe UI", sans-serif;
      color: var(--text-primary);
      background: var(--page-bg);
      line-height: 1.6;
    }
    a, a:visited { color: var(--link-color); }
    a:hover { color: var(--accent-blue); }

    .wrap { max-width: var(--max); margin: 0 auto; padding: 0 20px 80px; }

    .topbar {
      min-height: 74px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      position: sticky;
      top: 0;
      z-index: 1000;
      width: calc(100% + 40px);
      margin-left: -20px;
      margin-right: -20px;
      padding-left: 20px;
      padding-right: 20px;
      background: var(--nav-bg);
    }

    .brand {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      font-family: "Pinyon Script", cursive;
      font-size: clamp(1.9rem, 2.8vw, 2.4rem);
      text-decoration: none;
      color: var(--text-primary);
      line-height: 1;
    }
    .brand img { width: 64px; height: 64px; object-fit: contain; }

    .nav { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; justify-content: flex-end; }
    .nav a { font-size: 0.92rem; color: var(--text-secondary); text-decoration: none; padding: 8px 12px; border-radius: 10px; }
    .nav a.active { text-decoration: underline; text-underline-offset: 3px; }
    .nav .app-btn {
      border: 1px solid rgba(147, 197, 253, 0.4);
      border-radius: 12px;
      padding: 8px 16px;
      font-weight: 500;
      background: linear-gradient(180deg, var(--primary-blue), var(--dark-blue));
      color: #f8fafc;
    }
    
    .blog-header { text-align: center; padding: 60px 0 40px; }
    .blog-header h1 { font-size: clamp(2.3rem, 5vw, 3.5rem); letter-spacing: -0.02em; margin-bottom: 10px; }
    .blog-header .rainbow {
      background: linear-gradient(90deg, #4ade80 0%, #60a5fa 55%, #818cf8 100%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }
    .blog-header p { color: var(--text-secondary); font-size: 1.1rem; }

    .posts-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 30px;
      margin-top: 20px;
    }

    .post-card {
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: 16px;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      transition: transform 0.2s ease, border-color 0.2s ease;
      text-decoration: none;
    }
    
    .post-card:hover {
      transform: translateY(-4px);
      border-color: var(--primary-blue);
    }

    .post-image {
      width: 100%;
      height: 200px;
      background: #1e293b;
      object-fit: cover;
    }

    .post-content { padding: 24px; flex: 1; display: flex; flex-direction: column; }
    .post-title { 
      font-size: 1.3rem; 
      font-weight: 700; 
      margin-bottom: 10px; 
      line-height: 1.3; 
      background: linear-gradient(90deg, #e5e7eb 0%, #4ade80 50%, #60a5fa 100%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }
    .post-summary { color: var(--text-secondary); font-size: 0.95rem; margin-bottom: 20px; flex: 1; }
    .post-date { color: var(--text-muted); font-size: 0.85rem; font-weight: 500; }

    .footer { text-align: center; margin-top: 80px; color: var(--text-muted); font-size: 0.9rem; }

    @media (max-width: 980px) {
      .topbar { min-height: auto; padding-top: 12px; padding-bottom: 4px; flex-direction: column; align-items: flex-start; }
      .nav { justify-content: flex-start; width: 100%; }
    }
  </style>
</head>
<body>
  <div class="wrap">
    <header class="topbar">
      <a href="/" class="brand"><img src="/Aucto_Hat_Transparent.png" alt="Aucto" />Auctologue</a>
      <nav class="nav" aria-label="Main navigation">
        <a href="/">Overview</a>
        <a href="/plans.html">Plans</a>
        <a href="/features.html">Features</a>
        <a href="/blog/" class="active">Blog</a>
        <a href="/about.html">About</a>
        <a href="https://app.auctologue.com/" class="app-btn">Open WebApp</a>
      </nav>
    </header>

    <div class="blog-header">
      <h1><span class="rainbow">Auctologue</span> Blog</h1>
      <p>Stories from the auction industry and technical tutorials.</p>
    </div>

    <div class="posts-grid">
      {% for post in collections.blog | reverse %}
        <a href="{{ post.url }}" class="post-card">
          {% if post.data.featuredImage %}
            <img src="{{ post.data.featuredImage }}" alt="{{ post.data.title }}" class="post-image" />
          {% else %}
            <div class="post-image" style="display:flex;align-items:center;justify-content:center;color:#475569;">No Image</div>
          {% endif %}
          <div class="post-content">
            <h2 class="post-title">{{ post.data.title }}</h2>
            <p class="post-summary">{{ post.data.summary | default("Read this post to learn more about our latest updates and insights.") }}</p>
            <p class="post-date">{{ post.date | date }}</p>
          </div>
        </a>
      {% endfor %}
    </div>

    <footer class="footer"><a href="/privacy-policy.html">Privacy &amp; Terms</a></footer>
  </div>
</body>
</html>