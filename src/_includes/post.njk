<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }} - Auctologue Blog</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Pinyon+Script&display=swap" rel="stylesheet" />
  <style>
    :root {
      --primary-blue: #3b82f6;
      --dark-blue: #2563eb;
      --accent-blue: #60a5fa;
      --brand-blue: #93c5fd;
      --text-primary: #e5e7eb;
      --text-secondary: #cbd5e1;
      --text-muted: #94a3b8;
      --bg: #0b1220;
      --border: #1f2937;
      --panel: #111827;
      --radius: 18px;
      --max: 1120px;
      --link-color: #93c5fd;
      --page-bg: radial-gradient(circle at 8% 0%, rgba(59, 130, 246, 0.22), transparent 42%), radial-gradient(circle at 92% 12%, rgba(59, 130, 246, 0.15), transparent 38%), linear-gradient(180deg, #162744 0%, #111f35 26%, #0f1a2d 55%, var(--bg) 100%);
      --nav-bg: #1b3760;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: "Inter", system-ui, -apple-system, "Segoe UI", sans-serif;
      color: var(--text-primary);
      background: var(--page-bg);
      line-height: 1.6;
    }
    a, a:visited { color: var(--link-color); }
    a:hover { color: var(--accent-blue); }

    .wrap {
      max-width: var(--max);
      margin: 0 auto;
      padding: 0 20px 80px;
    }

    .topbar {
      min-height: 74px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      position: sticky;
      top: 0;
      z-index: 1000;
      width: calc(100% + 40px);
      margin-left: -20px;
      margin-right: -20px;
      padding-left: 20px;
      padding-right: 20px;
      background: var(--nav-bg);
      opacity: 1;
      backdrop-filter: none;
      border-bottom: 0;
    }

    .brand {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      font-family: "Pinyon Script", cursive;
      font-size: clamp(1.9rem, 2.8vw, 2.4rem);
      text-decoration: none;
      color: var(--text-primary);
      line-height: 1;
    }
    .brand img {
      width: 64px;
      height: 64px;
      object-fit: contain;
    }

    .nav {
      display: flex;
      align-items: center;
      gap: 14px;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .nav a {
      font-size: 0.92rem;
      color: var(--text-secondary);
      text-decoration: none;
      padding: 8px 12px;
      border-radius: 10px;
    }

    .nav a.active {
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    .nav .app-btn {
      border: 1px solid rgba(147, 197, 253, 0.4);
      border-radius: 12px;
      padding: 8px 16px;
      font-weight: 500;
      background: linear-gradient(180deg, var(--primary-blue), var(--dark-blue));
      color: #f8fafc;
    }
    
    .blog-content {
      max-width: 800px;
      margin: 40px auto;
      font-size: 1.1rem;
      line-height: 1.7;
    }
    
    .blog-content h1 {
      font-size: clamp(2rem, 5vw, 3rem);
      line-height: 1.2;
      margin-bottom: 10px;
      letter-spacing: -0.02em;
      font-weight: 700;
      background: linear-gradient(90deg, #e5e7eb 0%, #4ade80 40%, #60a5fa 100%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }
    
    .blog-content .meta {
      color: var(--text-muted);
      margin-bottom: 40px;
      font-size: 0.95rem;
    }
    
    .blog-content h2 { margin: 40px 0 20px; font-size: 1.8rem; }
    .blog-content h3 { margin: 30px 0 15px; font-size: 1.4rem; }
    .blog-content p { margin-bottom: 20px; color: var(--text-secondary); }
    .blog-content ul, .blog-content ol { margin-bottom: 20px; padding-left: 20px; color: var(--text-secondary); }
    .blog-content li { margin-bottom: 10px; }
    .blog-content blockquote { border-left: 4px solid var(--primary-blue); padding-left: 20px; margin: 20px 0; color: var(--text-primary); font-style: italic; }
    .blog-content img { max-width: 100%; height: auto; border-radius: 12px; margin: 20px 0; }
    
    .footer {
      text-align: center;
      margin-top: 60px;
      color: var(--text-muted);
      font-size: 0.9rem;
    }

    @media (max-width: 980px) {
      .topbar { min-height: auto; padding-top: 12px; padding-bottom: 4px; flex-direction: column; align-items: flex-start; }
      .nav { justify-content: flex-start; width: 100%; }
    }
  </style>
</head>
<body>
  <div class="wrap">
    <header class="topbar">
      <a href="/" class="brand"><img src="/Aucto_Hat_Transparent.png" alt="Aucto" />Auctologue</a>
      <nav class="nav" aria-label="Main navigation">
        <a href="/">Overview</a>
        <a href="/plans.html">Plans</a>
        <a href="/features.html">Features</a>
        <a href="/blog/" class="active">Blog</a>
        <a href="/about.html">About</a>
        <a href="https://app.auctologue.com/" class="app-btn">Open WebApp</a>
      </nav>
    </header>

    <main class="blog-content">
      <h1>{{ title }}</h1>
      <p class="meta">{{ date | date }}</p>
      
      {% if featuredImage %}
        <img src="{{ featuredImage }}" alt="{{ title }}" />
      {% endif %}

      {{ content | safe }}
    </main>

    <footer class="footer"><a href="/privacy-policy.html">Privacy &amp; Terms</a></footer>
  </div>
</body>
</html>